pipeline{
    agent any
    tools{
        maven 'MVN3.9'
        jdk  'JDK17'
    }
    stages{
        stage('Clone the Code for Vprofile'){
            steps{
                git branch: 'atom', url: 'https://github.com/hkhcoder/vprofile-project.git'
            }
        }
        stage('Build the code'){
            steps{
                sh 'mvn install -DskipTests'
            }
            post{
                success{
                    echo 'Archiving the target'
                    archiveArtifacts artifacts: '**/*.war'
                }
            }
        } 
        stage('Test the code'){
            steps{
                sh 'mvn test'
            }
        }
        stage('Checkstyle test'){
            steps{
                sh 'mvn checkstyle:checkstyle'
            }
        }
        stage('perform Sonar Analysis'){
            environment{
                scannerHome = tool 'Sonar8'
            }
            steps{
                withSonarQubeEnv('SonarServer'){
                sh '''${scannerHome}/bin/sonar-scanner \
                -Dsonar.projectKey=VprofileKey \
                -Dsonar.projectName='VprofileApp' \
                -Dsonar.projectVersion=1.1.0 \
                -Dsonar.sources=src/ \
                -Dsonar.java.binaries=target/classes \
                -Dsonar.junit.reportsPath=target/surefire-reports \
                -Dsonar.coverage.jacoco.xmlReportPaths=/target/site/jacoco/jacoco.xml \
                -Dsonar.java.checkstyle.reportPaths=/target/checkstyle-result.xml'''
                }
            }
         }
         stage("Quality Gate"){
             steps{
                 timeout(time: 1, unit: 'HOURS') {
                     waitForQualityGate abortPipeline: true
                 }
             }
         }
         stage('Upload to Nexus') {
            steps {
                script {
                    nexusArtifactUploader(
                        nexusVersion: 'nexus3',
                        protocol: 'http',
                        nexusUrl: '172.31.78.88:8081',
                        groupId: 'QA',
                        version: "${BUILD_ID}_${BUILD_TIMESTAMP}",
                        repository: 'vprofileRepo',
                        credentialsId: 'NexusCred',
                        artifacts: [
                            [
                                artifactId: 'VProfileApp',
                                classifier: '',
                                file: 'target/vprofile-v2.war',
                                type: 'war'
                            ]
                        ]
                    )
                }
            }
        }
    }
}
